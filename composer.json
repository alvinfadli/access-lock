{
    "name": "alvinfadli/access-lock",
    "description": "A lightweight password-protected access gate middleware for Laravel applications.",
    "keywords": ["laravel", "middleware", "access", "password", "gate"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Alvin Fadli",
            "email": "alvinfadli@example.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^10.0|^11.0",
        "illuminate/contracts": "^10.0|^11.0",
        "illuminate/http": "^10.0|^11.0",
        "illuminate/routing": "^10.0|^11.0",
        "illuminate/session": "^10.0|^11.0",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/hashing": "^10.0|^11.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "AlvinFadli\\AccessLock\\": "src/"
        },
        "files": [
            "src/Helpers/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "AlvinFadli\\AccessLock\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AlvinFadli\\AccessLock\\AccessLockServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
